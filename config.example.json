{
  "region": "ap-shanghai",
  "endpoint": "cfw.tencentcloudapi.com",
  "credential_profiles": [
    "default"
  ],
  "tencent_scan_ips": [],
  "company_scan_ips": [],
  "block_ip": {
    "enabled": true,
    "direction_list": "0,1",
    "end_time": "2099-12-31 23:59:59",
    "fw_type": 1,
    "cover_duplicate": 1,
    "batch_size": 50,
    "comment_prefix": "cfw-alert-automation"
  },
  "lookback_hours": 1,
  "daily_report_time": "17:50",
  "state_db": {
    "enabled": false,
    "dsn_env": "CFW_STATE_DB_DSN",
    "schema": "public",
    "connect_timeout_seconds": 5
  },
  "wecom": {
    "enabled": false,
    "webhook_url": "",
    "hourly_enabled": false,
    "daily_enabled": true,
    "notify_on_empty": true,
    "timeout_seconds": 15,
    "max_bytes": 3800,
    "manual_enabled": true,
    "manual_at_all": true,
    "manual_max_items": 6,
    "manual_webhook_url": "",
    "hourly_at_all_on_critical": false
  },
  "realtime_triage": {
    "enabled": true,
    "interval_seconds": 60,
    "lookback_minutes": 10,
    "max_records_per_round": 80,
    "dedupe_hours": 24,
    "manual_notify_cooldown_minutes": 240,
    "auto_dispose": true,
    "push_manual": true,
    "state_file": "data/realtime-poll-state.json"
  },
  "llm": {
    "enabled": true,
    "provider": "codex_direct",
    "model": "gpt-5.5",
    "reasoning_effort": "medium",
    "codex_responses_url": "https://chatgpt.com/backend-api/codex/responses",
    "codex_path": "codex.cmd",
    "rule_parse": {
      "enabled": true,
      "timeout_seconds": 90
    },
    "routing": {
      "batch_triage": "codex_direct",
      "source_review": "codex_direct",
      "agent_triage": "codex_direct",
      "critical_review": "codex_direct",
      "rule_parse": "codex_direct",
      "fallback": "codex_direct"
    },
    "providers": {
      "codex_direct": {
        "type": "codex_direct",
        "model": "gpt-5.5",
        "url": "https://chatgpt.com/backend-api/codex/responses",
        "reasoning_effort": "high",
        "timeout_seconds": 300
      },
      "codex_api": {
        "type": "openai_compatible",
        "base_url": "https://api.openai.com/v1",
        "api_key_env": "OPENAI_API_KEY",
        "model": "gpt-5.5",
        "json_mode": true,
        "timeout_seconds": 300
      },
      "deepseek_fast": {
        "type": "openai_compatible",
        "base_url": "https://api.deepseek.com",
        "api_key_env": "DEEPSEEK_API_KEY",
        "model": "deepseek-v4-flash",
        "json_mode": true,
        "timeout_seconds": 180
      },
      "deepseek_reasoner": {
        "type": "openai_compatible",
        "base_url": "https://api.deepseek.com",
        "api_key_env": "DEEPSEEK_API_KEY",
        "model": "deepseek-v4-pro",
        "json_mode": true,
        "reasoning_effort": "high",
        "timeout_seconds": 240
      },
      "glm_fast": {
        "type": "openai_compatible",
        "base_url": "https://open.bigmodel.cn/api/paas/v4",
        "api_key_env": "GLM_API_KEY",
        "model": "glm-5.2",
        "json_mode": true,
        "timeout_seconds": 180
      },
      "claude_api": {
        "type": "anthropic",
        "api_key_env": "ANTHROPIC_API_KEY",
        "model": "claude-sonnet-4-5",
        "max_tokens": 4096,
        "timeout_seconds": 240
      },
      "claude_subscription": {
        "type": "claude_cli",
        "command": ["claude", "-p", "--output-format", "text"],
        "model": "claude-code-subscription",
        "timeout_seconds": 240
      }
    },
    "max_workers": 3,
    "batch_size": 40,
    "timeout_seconds": 300,
    "ignore_user_config": true,
    "retry": {
      "max_retries": 2,
      "backoff_seconds": 2.0,
      "backoff_factor": 2.0
    },
    "source_review": {
      "enabled": true,
      "reasoning_effort": "medium",
      "high_reasoning_effort": "high",
      "batch_size": 60,
      "max_groups_per_run": 200,
      "max_evidence_chars": 600,
      "hydrate_missing_evidence": true,
      "review_all_with_evidence": true,
      "netflow_fetch_limit": 100
    },
    "agent_triage": {
      "enabled": false,
      "reasoning_effort": "high",
      "max_rounds": 6,
      "max_alerts_per_run": 40,
      "max_workers": 3,
      "max_alerts_hourly": 15
    },
    "alert_center_auto_dispose": {
      "enabled": true,
      "lookback_hours": 24,
      "timeout_seconds": 780,
      "deep_triage": true,
      "deep_triage_max": 120,
      "deep_lookback_hours": 2,
      "retry_max_per_run": 60
    },
    "auto_dispose": {
      "enabled": true,
      "ignore_results": [
        "未见成功证据",
        "扫描探测",
        "确认未成功"
      ],
      "omit_table_type": "AlertTable",
      "batch_size": 50,
      "ids_white_enabled": true,
      "ids_white_rule_type": "srcdst",
      "ids_white_fw_type": 7
    },
    "precheck": true,
    "precheck_timeout": 6,
    "proxy": ""
  },
  "agent": {
    "enabled": false,
    "ai_env_file": "/etc/cfw-ai.env",
    "policy_guard": {
      "high_alert_requires_evidence": true,
      "cloud_success_never_omit": true,
      "confirmed_success_never_omit": true
    },
    "custom_rules": {
      "enabled": true,
      "default_expire_days": 30,
      "require_confirm": true
    }
  }
}
