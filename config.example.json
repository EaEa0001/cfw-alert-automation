{
  "region": "ap-shanghai",
  "endpoint": "cfw.tencentcloudapi.com",
  "credential_profiles": [
    "default"
  ],
  "tencent_scan_ips": [],
  "company_scan_ips": [],
  "lookback_hours": 1,
  "daily_report_time": "17:50",
  "wecom": {
    "enabled": false,
    "webhook_url": "",
    "hourly_enabled": true,
    "daily_enabled": true,
    "notify_on_empty": true,
    "timeout_seconds": 15,
    "max_bytes": 3800,
    "manual_enabled": true,
    "manual_at_all": true,
    "manual_max_items": 10,
    "manual_webhook_url": "",
    "hourly_at_all_on_critical": true
  },
  "llm": {
    "enabled": true,
    "provider": "codex_direct",
    "model": "gpt-5.5",
    "reasoning_effort": "medium",
    "codex_responses_url": "https://chatgpt.com/backend-api/codex/responses",
    "codex_path": "codex.cmd",
    "max_workers": 3,
    "batch_size": 40,
    "timeout_seconds": 300,
    "ignore_user_config": true,
    "retry": {
      "max_retries": 2,
      "backoff_seconds": 2.0,
      "backoff_factor": 2.0
    },
    "source_review": {
      "enabled": true,
      "reasoning_effort": "medium",
      "high_reasoning_effort": "high",
      "batch_size": 60,
      "max_groups_per_run": 200,
      "max_evidence_chars": 600,
      "hydrate_missing_evidence": true,
      "review_all_with_evidence": true,
      "netflow_fetch_limit": 100
    },
    "agent_triage": {
      "enabled": false,
      "reasoning_effort": "high",
      "max_rounds": 6,
      "max_alerts_per_run": 30,
      "max_workers": 2
    },
    "alert_center_auto_dispose": {
      "enabled": true,
      "lookback_hours": 24,
      "timeout_seconds": 780,
      "deep_triage": true,
      "deep_triage_max": 120,
      "deep_lookback_hours": 2,
      "retry_max_per_run": 60
    },
    "auto_dispose": {
      "enabled": true,
      "ignore_results": [
        "未见成功证据",
        "扫描探测",
        "确认未成功"
      ],
      "omit_table_type": "AlertTable",
      "batch_size": 50,
      "ids_white_enabled": true,
      "ids_white_rule_type": "srcdst",
      "ids_white_fw_type": 7
    },
    "precheck": true,
    "precheck_timeout": 6
  }
}